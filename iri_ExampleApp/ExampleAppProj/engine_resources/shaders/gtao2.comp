layout(set=0, binding = 0) uniform sampler2D _min_max_depth;

layout(r8, set=1, binding = 0) uniform writeonly image2D _gtao_tex;

layout(set=2, binding=0) uniform ubo {
    mat4  _inv_proj_mat;
    uvec2 _ao_tex_size;

    uint  _sample_count;
    uint  _slice_count;
    float _sample_radius;
    float _hit_thickness;

    int _min_max_depth_mip_level;
    float _strength;
};

// https://graphics.stanford.edu/%7Eseander/bithacks.html
uint count_bits(uint value) {
    value = value - ((value >> 1u) & 0x55555555u);
    value = (value & 0x33333333u) + ((value >> 2u) & 0x33333333u);
    return ((value + (value >> 4u) & 0xF0F0F0Fu) * 0x1010101u) >> 24u;
}

// https://cdrinmatane.github.io/posts/ssaovb-code/
#define SECTOR_COUNT 32u
#define SECTOR_COUNT_F 32.0f
#define ONE_OVER_SECTOR_COUNT 1.0f / 32.0f

uint update_sectors(float minHorizon, float maxHorizon, uint outBitfield) {
    uint startBit = uint(minHorizon * SECTOR_COUNT_F);
    uint horizonAngle = uint(floor((maxHorizon - minHorizon) * SECTOR_COUNT_F));
    
    uint angleBit = horizonAngle > 0u ? uint(0xFFFFFFFFu >> (SECTOR_COUNT - horizonAngle)) : 0u;
    //uint angleBit = horizonAngle > 0u ?  0u : uint(0xFFFFFFFFu >> (SECTOR_COUNT - horizonAngle));

    uint currentBitfield = angleBit << startBit;
    return outBitfield | currentBitfield;
}


float sample_depth(vec2 uv) {



