    // so we use point sampling for now. Its also much faster.

    vec2 direct_sample = textureLod(_min_max_depth, uv, float(_min_max_depth_mip_level)).xy;
    return direct_sample.x;

    vec2 texel_f = uv * vec2(_ao_tex_size);
    ivec2 texel = ivec2(texel_f);

    ivec2 texel_00 = clamp(texel  + ivec2(0,0), ivec2(0,0), ivec2(_ao_tex_size) -1);
    // //ivec2 texel_01 = clamp(texel  + ivec2(0,1), ivec2(0,0), ivec2(_ao_tex_size) -1);
    // //ivec2 texel_10 = clamp(texel  + ivec2(1,0), ivec2(0,0), ivec2(_ao_tex_size) -1);
    // //ivec2 texel_11 = clamp(texel  + ivec2(1,1), ivec2(0,0), ivec2(_ao_tex_size) -1);


    // //vec2 fraction = fract(texel_f); 
    vec2 depth_00 = texelFetch(_min_max_depth, texel_00, _min_max_depth_mip_level).xy;
    // //vec2 depth_01 = texelFetch(_min_max_depth, texel_01, _min_max_depth_mip_level).xy;
    // //vec2 depth_10 = texelFetch(_min_max_depth, texel_10, _min_max_depth_mip_level).xy;
    // //vec2 depth_11 = texelFetch(_min_max_depth, texel_11, _min_max_depth_mip_level).xy;

    // // bilinear interpolation
    // //vec4 weights = vec4(0.0f);
    // //weights.x = (1 - fraction.x) * (1 - fraction.y);
    // //weights.y = (1 - fraction.x) * (    fraction.y);
    // //weights.z = (    fraction.x) * (1 - fraction.y);
    // //weights.w = (    fraction.x) * (    fraction.y);

    // //vec2 depth = depth_00;
    // vec2 depth = vec2(0.0f);
    // //depth += depth_00 * weights.x; 
    // //depth += depth_01 * weights.y;
    // //depth += depth_10 * weights.z;
    // //depth += depth_11 * weights.w;

    // //depth = max(depth, depth_00);
    // depth = depth_00;
    return depth_00.y;
}

vec3 reconstruct_normal_from_depth(uvec2 depth_tex_dimentions, vec2 uv_center, float depth_at_uv_center, vec3 pos_at_uv_center, mat4 inv_matrix) {

    vec2 one_over_dim = vec2(1.0f) / vec2(depth_tex_dimentions);

    vec2 uv_up      = fma(vec2( 0.0f,  1.0f) , one_over_dim, uv_center);
    vec2 uv_right   = fma(vec2( 1.0f,  0.0f) , one_over_dim, uv_center);
    vec2 uv_down    = fma(vec2( 0.0f, -1.0f) , one_over_dim, uv_center);
    vec2 uv_left    = fma(vec2(-1.0f,  0.0f) , one_over_dim, uv_center);

    float z_center  = depth_at_uv_center;
    float z_up      = sample_depth(uv_up   );
    float z_right   = sample_depth(uv_right);
    float z_down    = sample_depth(uv_down );
    float z_left    = sample_depth(uv_left );

    // 0 means up is better, 1 mean down is better
    uint best_z_vertical = abs(z_up - z_center) < abs(z_down - z_center) ? 0 : 1;
    // 0 means right is better, 1 mean left is better
    uint best_z_horizontal   = abs(z_right - z_center) < abs(z_left - z_center) ? 0 : 1;

    vec3 p0 = pos_at_uv_center;
    vec3 p1 = vec3(0.0f);
    vec3 p2 = vec3(0.0f);

    if (best_z_vertical == 0 && best_z_horizontal == 0){
        // up and right
        p1 = reconstruct_position_from_depth(uv_right, z_right  , inv_matrix);
        p2 = reconstruct_position_from_depth(uv_up, z_up  , inv_matrix);
    } else if (best_z_vertical == 0 && best_z_horizontal == 1){
        // up and left        
        p1 = reconstruct_position_from_depth(uv_up  , z_up  , inv_matrix);
        p2 = reconstruct_position_from_depth(uv_left, z_left, inv_matrix);
    } else if (best_z_vertical == 1 && best_z_horizontal == 0){
        // down and right
        p1 = reconstruct_position_from_depth(uv_down, z_down, inv_matrix);
        p2 = reconstruct_position_from_depth(uv_right, z_right, inv_matrix);
    } else if (best_z_vertical == 1 && best_z_horizontal == 1){
        // down and left
        p1 = reconstruct_position_from_depth(uv_left, z_left, inv_matrix);
        p2 = reconstruct_position_from_depth(uv_down, z_down, inv_matrix);
    }

    vec3 normal = normalize(cross(p2 - p0, p1 - p0));
    
    return normal;
}

